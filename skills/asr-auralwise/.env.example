# AuralWise API Key —— 形如 asr_xxxx（44 位，asr_ 开头）
# 在 auralwise.cn 账号设置页创建。此文件已 .gitignore，不会进 skill 内容。
# 变量名二选一皆可：
ASR_AURALWISE_API_KEY=
# AURALWISE_API_KEY=

# 可选配置
# AURALWISE_BASE_URL=https://api.auralwise.cn/v1
# ASR_POLL_INTERVAL_MS=30000
# ASR_POLL_TIMEOUT_MS=1800000
# ASR_OUT_ROOT=/Users/otto/Downloads
